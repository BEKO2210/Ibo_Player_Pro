{
  "name": "@premium-player/epg-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Premium TV Player — EPG worker (XMLTV fetch + parse + persist)",
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc -p tsconfig.build.json",
    "start": "TS_NODE_PROJECT=tsconfig-paths-runtime.json node -r tsconfig-paths/register dist/epg-worker/src/main.js",
    "start:dev": "ts-node-dev --transpile-only --respawn --require tsconfig-paths/register src/main.ts",
    "start:once": "WORKER_RUN_ONCE=true npm run start",
    "prisma:generate": "prisma generate --schema ../api/prisma/schema.prisma",
    "pretest": "npm run prisma:generate",
    "test": "jest"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.10",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.3.10",
    "@nestjs/platform-express": "^10.3.10",
    "@nestjs/terminus": "^10.2.3",
    "@premium-player/parsers": "file:../../packages/parsers",
    "@prisma/client": "^5.18.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "firebase-admin": "^12.3.1",
    "google-auth-library": "^9.15.1",
    "ioredis": "^5.4.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.12",
    "jest": "^29.7.0",
    "prisma": "^5.18.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  },
  "engines": { "node": ">=20.11.0" },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testRegex": "src/.*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "tsconfig.json" }]
    },
    "moduleNameMapper": {
      "^@api/(.*)$": "<rootDir>/../api/src/$1"
    },
    "testEnvironment": "node"
  }
}
