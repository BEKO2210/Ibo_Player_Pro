# Premium TV Player API — environment template
# Copy to `.env` and adjust for local development.

NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=3000
LOG_LEVEL=log

# Postgres (matches infra/docker/docker-compose.yml defaults)
DATABASE_URL=postgresql://premium:premium@localhost:5432/premium_player?schema=public

# Redis (matches infra/docker/docker-compose.yml defaults)
REDIS_URL=redis://localhost:6379

# ----------------------------------------------------------------------------
# Firebase Admin SDK — used by the auth module to verify Firebase ID tokens.
# Provide credentials via ONE of the two options:
#
#   Option A) Single JSON blob (recommended for CI / k8s secrets):
#     FIREBASE_SERVICE_ACCOUNT_JSON='{"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n..."}'
#
#   Option B) Three discrete fields (local dev friendly):
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Note: newlines in the private key can be encoded as \n — they will be decoded on load.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"

# ----------------------------------------------------------------------------
# Billing (Google Play) — used by the billing worker + /v1/billing/* endpoints.
# The Firebase service account above MUST also be linked in the Google Play
# Console with the `androidpublisher` scope in GCP IAM.
BILLING_ANDROID_PACKAGE_NAME=com.premiumtvplayer.app
BILLING_PRODUCT_ID_SINGLE=premium_player_single
BILLING_PRODUCT_ID_FAMILY=premium_player_family
BILLING_WORKER_POLL_INTERVAL_MS=15000

# ----------------------------------------------------------------------------
# Source credential envelope encryption (AES-256-GCM).
# 64 hex chars = 32 raw bytes. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotate by versioning (encryption_version column on source_credentials).
SOURCE_ENCRYPTION_KEY=
SOURCE_ENCRYPTION_KMS_KEY_ID=local-dev-v1

# ----------------------------------------------------------------------------
# Profile PIN — Argon2id lockout policy.
PIN_MAX_FAILED_ATTEMPTS=5
PIN_LOCKOUT_DURATION_MS=900000
