# Premium TV Player API — environment template
# Copy to `.env` and adjust for local development.

NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=3000
LOG_LEVEL=log

# Postgres (matches infra/docker/docker-compose.yml defaults)
DATABASE_URL=postgresql://premium:premium@localhost:5432/premium_player?schema=public

# Redis (matches infra/docker/docker-compose.yml defaults)
REDIS_URL=redis://localhost:6379
