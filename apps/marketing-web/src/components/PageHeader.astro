---
interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
}
const { eyebrow, title, lede } = Astro.props;
---
<section class="page-header">
  <div class="container">
    {eyebrow && <p class="t-label-small eyebrow">{eyebrow}</p>}
    <h1 class="t-display page-title">{title}</h1>
    {lede && <p class="page-lede">{lede}</p>}
  </div>
</section>

<style>
  .page-header {
    padding-block: clamp(40px, 7vw, 80px) clamp(24px, 4vw, 40px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    background:
      radial-gradient(600px 320px at 80% 20%, rgba(96, 165, 250, 0.08), transparent 70%);
  }
  .eyebrow { margin: 0 0 var(--space-s); color: var(--color-accent-cyan); }
  .page-title { margin: 0; color: var(--color-on-surface-high); }
  .page-lede {
    margin: var(--space-m) 0 0;
    font-size: 20px;
    line-height: 1.5;
    max-width: 720px;
    color: var(--color-on-surface-muted);
  }
</style>
