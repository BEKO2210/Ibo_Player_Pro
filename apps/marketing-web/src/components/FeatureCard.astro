---
/*
  Feature card — now takes an `<Icon />` component as the named "icon" slot.
  The slot renders the SVG directly (no opaque placeholder box).

  Usage:
    <FeatureCard title="..." body="...">
      <IconSources slot="icon" />
    </FeatureCard>
*/
interface Props {
  title: string;
  body: string;
}
const { title, body } = Astro.props;
---
<article class="feature-card">
  <div class="icon-wrap" aria-hidden="true">
    <slot name="icon" />
  </div>
  <h3 class="t-title-large feature-title">{title}</h3>
  <p class="t-body-small feature-body">{body}</p>
</article>

<style>
  .feature-card {
    position: relative;
    padding: clamp(20px, 2.4vw, 32px);
    border-radius: var(--radius-l);
    background: linear-gradient(180deg, rgba(29, 33, 40, 0.72), rgba(20, 23, 28, 0.72));
    border: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    flex-direction: column;
    gap: clamp(10px, 1.4vw, 16px);
    transition:
      transform var(--dur-short) var(--easing-premium),
      border-color var(--dur-short) var(--easing-premium),
      box-shadow var(--dur-short) var(--easing-premium);
  }
  .feature-card:hover {
    transform: translateY(-3px);
    border-color: rgba(96, 165, 250, 0.38);
    box-shadow: 0 20px 50px -28px rgba(59, 130, 246, 0.45);
  }

  .icon-wrap {
    width: 52px;
    height: 52px;
    border-radius: var(--radius-m);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent-cyan);
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.18), rgba(139, 92, 246, 0.12));
    border: 1px solid rgba(96, 165, 250, 0.2);
    box-shadow:
      0 8px 24px -10px rgba(59, 130, 246, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }
  .icon-wrap :global(svg) {
    width: 26px;
    height: 26px;
  }

  .feature-title { margin: 0; color: var(--color-on-surface-high); }
  .feature-body  { margin: 0; }
</style>
