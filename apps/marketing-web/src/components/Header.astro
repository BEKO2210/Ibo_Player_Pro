---
import Button from "./Button.astro";
const path = Astro.url.pathname;
const isActive = (p: string) => path === p || path.startsWith(p + "/");
const nav = [
  { href: "/features", label: "Features" },
  { href: "/pricing", label: "Pricing" },
  { href: "/download", label: "Download" },
];
---
<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="Premium TV Player home">
      <span class="brand-mark" aria-hidden="true"></span>
      <span class="brand-wordmark">Premium TV Player</span>
    </a>
    <nav class="primary-nav" aria-label="Primary">
      {nav.map((n) => (
        <a class:list={["nav-link", { "is-active": isActive(n.href) }]} href={n.href}>{n.label}</a>
      ))}
    </nav>
    <div class="header-cta">
      <Button href="/download" variant="primary" label="Get the app" />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    height: var(--header-height);
    display: flex;
    align-items: center;
    backdrop-filter: blur(18px) saturate(140%);
    -webkit-backdrop-filter: blur(18px) saturate(140%);
    background: rgba(5, 6, 8, 0.72);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-l);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-weight: 600;
    letter-spacing: 0.2px;
    color: var(--color-on-surface-high);
  }
  .brand-mark {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--color-accent-cyan), var(--color-accent-blue-deep));
    box-shadow: 0 6px 20px -6px rgba(59, 130, 246, 0.6);
  }
  .brand-wordmark { font-size: 15px; }
  @media (max-width: 640px) {
    .brand-wordmark { display: none; }
  }

  .primary-nav {
    display: none;
    gap: var(--space-l);
  }
  @media (min-width: 800px) {
    .primary-nav { display: inline-flex; }
  }
  .nav-link {
    font-size: 15px;
    color: var(--color-on-surface-muted);
    padding: 8px 4px;
    transition: color var(--dur-short) var(--easing-premium);
  }
  .nav-link:hover { color: var(--color-on-surface-high); }
  .nav-link.is-active { color: var(--color-on-surface-high); }

  .header-cta :global(.btn) {
    padding: 10px 18px;
    font-size: 14px;
  }
</style>
