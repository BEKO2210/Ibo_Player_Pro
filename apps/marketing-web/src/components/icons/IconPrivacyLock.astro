---
/* A padlock inside a shield with a checkmark — no tracking / privacy-first. */
interface Props { size?: number; class?: string }
const { size = 24, class: className } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
  <path d="M12 3 4 6v5.5c0 4.6 3.4 8.3 8 9.5 4.6-1.2 8-4.9 8-9.5V6L12 3z"/>
  <rect x="9" y="10.5" width="6" height="5" rx="1"/>
  <path d="M10 10.5V9a2 2 0 0 1 4 0v1.5"/>
  <path d="M10.5 13l1 1 2-2" stroke-width="1.6"/>
</svg>
