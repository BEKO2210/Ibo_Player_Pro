---
import { link, asset } from "../utils/link";
import LocaleSwitcher from "./LocaleSwitcher.astro";
import { getLocaleFromPath } from "../utils/i18n";

const path = Astro.url.pathname;
const locale = getLocaleFromPath(path);
const year = new Date().getFullYear();
const logoHref = asset("/logo.png");

const copy = {
  de: {
    footerLabel: "Footer-Navigation",
    product: "Produkt",
    legal: "Rechtliches",
    features: "Features",
    pricing: "Preise",
    download: "Download",
    privacy: "Datenschutz",
    imprint: "Impressum",
    rights: "Alle Rechte vorbehalten.",
  },
  en: {
    footerLabel: "Footer",
    product: "Product",
    legal: "Legal",
    features: "Features",
    pricing: "Pricing",
    download: "Download",
    privacy: "Privacy",
    imprint: "Imprint",
    rights: "All rights reserved.",
  },
  sq: {
    footerLabel: "Navigimi i fundit",
    product: "Produkti",
    legal: "Ligjore",
    features: "Veçoritë",
    pricing: "Çmimet",
    download: "Shkarko",
    privacy: "Privatësia",
    imprint: "Të dhënat ligjore",
    rights: "Të gjitha të drejtat e rezervuara.",
  },
}[locale];
---
<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <img class="brand-mark" src={logoHref} alt="" width="28" height="28" />
      <span>Premium TV Player</span>
    </div>
    <nav class="footer-nav" aria-label={copy.footerLabel}>
      <div class="footer-col">
        <h4 class="t-label-small">{copy.product}</h4>
        <a href={link("/features", locale)}>{copy.features}</a>
        <a href={link("/pricing", locale)}>{copy.pricing}</a>
        <a href={link("/download", locale)}>{copy.download}</a>
      </div>
      <div class="footer-col">
        <h4 class="t-label-small">{copy.legal}</h4>
        <a href={link("/legal/privacy", locale)}>{copy.privacy}</a>
        <a href={link("/legal/imprint", locale)}>{copy.imprint}</a>
      </div>
    </nav>
    <div class="footer-meta">
      <LocaleSwitcher current={locale} pathname={path} />
      <p class="footer-note t-body-small">
        © {year} Belkis Aslani. {copy.rights}
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-huge);
    padding-block: var(--space-xxl);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    background: linear-gradient(180deg, transparent, rgba(255, 255, 255, 0.02));
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }
  @media (min-width: 800px) {
    .footer-inner {
      grid-template-columns: 1fr 2fr 1fr;
      align-items: start;
    }
  }
  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-on-surface-high);
    font-weight: 600;
  }
  .brand-mark {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }
  .footer-nav {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-xl);
  }
  .footer-col { display: flex; flex-direction: column; gap: var(--space-s); }
  .footer-col h4 { margin: 0 0 4px; color: var(--color-on-surface-muted); }
  .footer-col a {
    color: var(--color-on-surface);
    transition: color var(--dur-short) var(--easing-premium);
  }
  .footer-col a:hover { color: var(--color-on-surface-high); }

  .footer-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    align-items: flex-start;
  }
  @media (min-width: 800px) {
    .footer-meta { align-items: flex-end; text-align: right; }
  }
  .footer-note { margin: 0; }
</style>
