---
import Button from "./Button.astro";
import { link } from "../utils/link";

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  primaryCta?: { href: string; label: string };
  secondaryCta?: { href: string; label: string };
}
const { eyebrow, title, subtitle, primaryCta, secondaryCta } = Astro.props;

const animatedLogoHref = link("/logo-animation.gif");
const staticLogoHref = link("/logo.png");
---
<section class="hero">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="container hero-inner">
    <div class="hero-copy">
      {eyebrow && (
        <p class="t-label-small hero-eyebrow">
          <span class="dot" aria-hidden="true"></span>{eyebrow}
        </p>
      )}
      <h1 class="t-display-hero hero-title">{title}</h1>
      {subtitle && <p class="hero-subtitle">{subtitle}</p>}
      {(primaryCta || secondaryCta) && (
        <div class="hero-ctas">
          {primaryCta && <Button href={primaryCta.href} label={primaryCta.label} variant="primary" />}
          {secondaryCta && <Button href={secondaryCta.href} label={secondaryCta.label} variant="secondary" />}
        </div>
      )}
    </div>

    {/*
      Visual — the animated logo GIF on a black backdrop.
      The GIF has a black background; the containing surface is the same
      pure black so the GIF edges are invisible. A subtle brand glow
      sits BEHIND the black surface, leaking only slightly around the edge
      via the thin inner border.
    */}
    <div class="hero-visual" aria-hidden="true">
      <div class="visual-glow"></div>
      <div class="visual-surface">
        <img
          class="visual-logo"
          src={animatedLogoHref}
          width="520"
          height="520"
          alt=""
          loading="eager"
          decoding="async"
          onerror={`this.onerror=null;this.src='${staticLogoHref}';`}
        />
      </div>
    </div>
  </div>
</section>

<style>
  /*
    Golden-ratio composition:
      copy column : visual column = 1.618 : 1
      hero vertical padding uses phi-scaled clamps
  */
  .hero {
    position: relative;
    padding-block: clamp(48px, 7.4vw, 112px) clamp(64px, 9vw, 144px);
    overflow: hidden;
    isolation: isolate;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(650px 420px at 78% 36%, rgba(96, 165, 250, 0.18), transparent 70%),
      radial-gradient(540px 420px at 18% 78%, rgba(139, 92, 246, 0.12), transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(32px, 5vw, 72px);
    align-items: center;
  }
  /* Golden-ratio split at wide widths: 1.618fr (copy) : 1fr (visual) */
  @media (min-width: 960px) {
    .hero-inner { grid-template-columns: 1.618fr 1fr; gap: clamp(48px, 6vw, 96px); }
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    gap: clamp(16px, 2vw, 24px);
    max-width: 61.8ch; /* phi-based line length */
  }
  .hero-eyebrow {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: var(--space-s);
    color: var(--color-accent-cyan);
  }
  .dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--color-accent-cyan);
    box-shadow: 0 0 12px var(--color-accent-cyan);
    animation: pulse 2.6s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { transform: scale(1);   opacity: 1; }
    50%      { transform: scale(0.8); opacity: 0.6; }
  }

  .hero-title {
    margin: 0;
    color: var(--color-on-surface-high); /* fallback */
    background: linear-gradient(180deg, #fff 0%, #bfc9d8 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    word-wrap: break-word;
    overflow-wrap: break-word;
    hyphens: auto;
  }
  @supports not (-webkit-background-clip: text) {
    .hero-title { color: var(--color-on-surface-high); -webkit-text-fill-color: currentColor; }
  }

  .hero-subtitle {
    margin: 0;
    font-size: clamp(17px, 1.4vw, 20px);
    line-height: 1.618; /* phi */
    color: var(--color-on-surface-muted);
  }
  .hero-ctas {
    display: inline-flex;
    flex-wrap: wrap;
    gap: var(--space-m);
    margin-top: var(--space-s);
  }

  /* Visual stack: glow → black surface → GIF. Black surface matches GIF bg */
  .hero-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }
  .visual-glow {
    position: absolute;
    inset: -10%;
    border-radius: 50%;
    background:
      radial-gradient(closest-side, rgba(59, 130, 246, 0.45), transparent 70%),
      radial-gradient(closest-side, rgba(139, 92, 246, 0.25), transparent 80%);
    filter: blur(40px);
    pointer-events: none;
    z-index: 0;
  }
  .visual-surface {
    position: relative;
    z-index: 1;
    /* Pure black — identical to the GIF's black background so there is
       NO visible seam between GIF and surface. */
    background: #000;
    border-radius: 24px;
    padding: clamp(12px, 2vw, 24px);
    box-shadow:
      0 40px 80px -30px rgba(0, 0, 0, 0.8),
      0 0 0 1px rgba(96, 165, 250, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    width: 100%;
    max-width: 520px;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .visual-logo {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: #000; /* belt-and-braces: same bg behind the raster GIF */
  }
</style>
