---
import Button from "./Button.astro";
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  primaryCta?: { href: string; label: string };
  secondaryCta?: { href: string; label: string };
}
const { eyebrow, title, subtitle, primaryCta, secondaryCta } = Astro.props;
---
<section class="hero">
  <div class="container hero-inner">
    <div class="hero-copy">
      {eyebrow && (
        <p class="t-label-small hero-eyebrow">
          <span class="dot" aria-hidden="true"></span>{eyebrow}
        </p>
      )}
      <h1 class="t-display-hero hero-title">{title}</h1>
      {subtitle && <p class="hero-subtitle">{subtitle}</p>}
      {(primaryCta || secondaryCta) && (
        <div class="hero-ctas">
          {primaryCta && <Button href={primaryCta.href} label={primaryCta.label} variant="primary" />}
          {secondaryCta && <Button href={secondaryCta.href} label={secondaryCta.label} variant="secondary" />}
        </div>
      )}
    </div>
    <div class="hero-visual" aria-hidden="true">
      <div class="frame">
        <div class="frame-inner">
          <div class="frame-hero"></div>
          <div class="frame-row">
            <div></div><div></div><div></div><div></div>
          </div>
          <div class="frame-row">
            <div></div><div></div><div></div><div></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(40px, 8vw, 96px) clamp(56px, 10vw, 128px);
    overflow: hidden;
  }
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(600px 400px at 70% 30%, rgba(96, 165, 250, 0.14), transparent 70%),
      radial-gradient(500px 400px at 20% 80%, rgba(139, 92, 246, 0.1), transparent 70%);
    pointer-events: none;
  }
  .hero-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xxl);
    align-items: center;
  }
  @media (min-width: 960px) {
    .hero-inner { grid-template-columns: 1.1fr 1fr; gap: var(--space-hero); }
  }
  .hero-copy { display: flex; flex-direction: column; gap: var(--space-l); }
  .hero-eyebrow {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: var(--space-s);
    color: var(--color-accent-cyan);
  }
  .dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--color-accent-cyan);
    box-shadow: 0 0 12px var(--color-accent-cyan);
  }
  .hero-title {
    margin: 0;
    color: var(--color-on-surface-high); /* fallback */
    background: linear-gradient(180deg, #fff 0%, #cdd6e3 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    word-wrap: break-word;
    overflow-wrap: break-word;
    hyphens: auto;
  }
  @supports not (-webkit-background-clip: text) {
    .hero-title { color: var(--color-on-surface-high); -webkit-text-fill-color: currentColor; }
  }
  .hero-subtitle {
    margin: 0;
    font-size: 20px;
    line-height: 1.5;
    max-width: 560px;
    color: var(--color-on-surface-muted);
  }
  .hero-ctas {
    display: inline-flex;
    flex-wrap: wrap;
    gap: var(--space-m);
    margin-top: var(--space-s);
  }

  /* Decorative "TV frame" visual — placeholder until real screenshot lands in Run 3 */
  .hero-visual { display: flex; justify-content: center; }
  .frame {
    width: 100%;
    max-width: 520px;
    aspect-ratio: 16 / 10;
    border-radius: var(--radius-xl);
    padding: 10px;
    background: linear-gradient(145deg, rgba(255,255,255,0.12), rgba(255,255,255,0.02));
    box-shadow: 0 40px 80px -30px rgba(0,0,0,0.7);
  }
  .frame-inner {
    width: 100%; height: 100%;
    border-radius: calc(var(--radius-xl) - 6px);
    background:
      radial-gradient(400px 260px at 30% 20%, rgba(59, 130, 246, 0.35), transparent 70%),
      linear-gradient(180deg, #0B0D11, #14171C);
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .frame-hero {
    flex: 2;
    border-radius: var(--radius-m);
    background: linear-gradient(135deg, var(--color-accent-blue-deep), var(--color-accent-violet));
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.12);
  }
  .frame-row {
    flex: 1;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }
  .frame-row > div {
    border-radius: var(--radius-s);
    background: linear-gradient(180deg, #1D2128, #14171C);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
  }
</style>
