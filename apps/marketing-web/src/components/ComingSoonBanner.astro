---
import { WAITLIST_MAILTO } from "../utils/link";
---
<aside class="coming-soon" role="status" aria-live="polite" data-coming-soon data-hidden="false">
  <div class="container cs-inner">
    <span class="cs-pill">Coming soon</span>
    <span class="cs-text">
      The app is in final preparation for Google Play.
      <a href={WAITLIST_MAILTO}>Get notified at launch</a>.
    </span>
    <button type="button" class="cs-dismiss" aria-label="Dismiss announcement" data-coming-soon-dismiss>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M6 6l12 12M6 18L18 6"/>
      </svg>
    </button>
  </div>
</aside>

<script is:inline>
  (function () {
    const KEY = "ptp_coming_soon_dismissed_v1";
    const el = document.querySelector("[data-coming-soon]");
    if (!el) return;
    try {
      if (localStorage.getItem(KEY) === "1") {
        el.setAttribute("data-hidden", "true");
      }
    } catch (_) {}
    const btn = el.querySelector("[data-coming-soon-dismiss]");
    if (btn) {
      btn.addEventListener("click", function () {
        el.setAttribute("data-hidden", "true");
        try { localStorage.setItem(KEY, "1"); } catch (_) {}
      });
    }
  })();
</script>

<style>
  .coming-soon {
    position: relative;
    z-index: 60;
    background: linear-gradient(135deg, var(--color-accent-blue-deep), var(--color-accent-violet));
    color: #fff;
    font-size: 13px;
    line-height: 1.4;
    overflow: hidden;
    transition: grid-template-rows var(--dur-medium) var(--easing-premium);
    display: grid;
    grid-template-rows: 1fr;
  }
  .coming-soon > .container {
    min-height: 0;
  }
  .coming-soon[data-hidden="true"] {
    grid-template-rows: 0fr;
  }
  .coming-soon[data-hidden="true"] > .container { visibility: hidden; }

  .cs-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    padding-block: 10px;
  }
  .cs-pill {
    flex-shrink: 0;
    display: inline-block;
    padding: 3px 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(6px);
    font-size: 11px;
    letter-spacing: 1.1px;
    font-weight: 700;
    text-transform: uppercase;
  }
  .cs-text { color: rgba(255, 255, 255, 0.92); flex: 1; min-width: 0; }
  .cs-text a {
    color: #fff;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .cs-dismiss {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    color: rgba(255, 255, 255, 0.85);
    background: rgba(255, 255, 255, 0.1);
    transition: background var(--dur-short) var(--easing-premium), color var(--dur-short) var(--easing-premium);
  }
  .cs-dismiss:hover { color: #fff; background: rgba(255, 255, 255, 0.2); }
</style>
