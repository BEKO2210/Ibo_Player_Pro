---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ComingSoonBanner from "../components/ComingSoonBanner.astro";
import { link } from "../utils/link";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
}
const {
  title,
  description = "A premium player for your own M3U, M3U8 and XMLTV sources. Lifetime license, no subscriptions, cloud-synced profiles. Launching soon on Google Play.",
  ogImage = "/og-default.png",
  noIndex = false,
} = Astro.props;

const siteOrigin = Astro.site?.origin ?? "https://premiumtvplayer.app";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? siteOrigin).toString();
const ogImageUrl = new URL(link(ogImage), Astro.site ?? siteOrigin).toString();
const faviconHref = link("/favicon.svg");
const sitemapHref = link("/sitemap-index.xml");
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#050608" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noIndex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:site_name" content="Premium TV Player" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <link rel="sitemap" href={sitemapHref} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <ComingSoonBanner />
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -100px;
    left: 16px;
    padding: 10px 14px;
    border-radius: 8px;
    background: var(--color-accent-blue);
    color: #fff;
    z-index: 100;
    transition: top 0.2s ease;
  }
  .skip-link:focus { top: 12px; }
</style>
