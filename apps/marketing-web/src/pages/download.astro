---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Section from "../components/Section.astro";
import Button from "../components/Button.astro";

const PLAY_STORE_URL = "https://play.google.com/store/apps/details?id=com.premiumtvplayer.app";
---
<BaseLayout
  title="Download Premium TV Player for Android TV"
  description="Download Premium TV Player on your Google TV or Android TV from the Google Play Store. Android 8.0 Oreo (API 26) or later."
>
  <PageHeader
    eyebrow="Download"
    title="Get it on your TV in under a minute."
    lede="Premium TV Player is available on Google Play for Android TV and Google TV devices. Sign in with the same Google account on your TV, hit install, and you're ready to go."
  />

  <Section>
    <div class="download">
      <div class="download-card">
        <p class="t-label-small platform">Android TV · Google TV</p>
        <h2 class="t-headline download-title">Install from Google Play</h2>
        <p class="t-body">
          Search for <strong>Premium TV Player</strong> on your TV, or open Google Play in a browser,
          sign in, and push the install to your TV from there.
        </p>
        <Button href={PLAY_STORE_URL} label="Open on Google Play" variant="primary" external />
        <p class="t-body-small store-note">
          Package: <code>com.premiumtvplayer.app</code>
        </p>
      </div>

      <aside class="requirements">
        <h3 class="t-title">System requirements</h3>
        <ul>
          <li><strong>Android 8.0 Oreo</strong> (API 26) or later</li>
          <li>Android TV or Google TV hardware with a Leanback launcher</li>
          <li>Active internet connection for sign-in, EPG sync &amp; billing</li>
          <li>At least 100 MB of free storage</li>
          <li>A Google account (for Play Billing)</li>
        </ul>

        <h3 class="t-title">Tested on</h3>
        <ul>
          <li>Google TV Streamer, Chromecast with Google TV, NVIDIA Shield TV</li>
          <li>Sony BRAVIA Google TV, TCL Google TV, Hisense Google TV</li>
          <li>Android TV emulator (API 30+)</li>
        </ul>
      </aside>
    </div>
  </Section>

  <Section eyebrow="Other platforms" title="Coming next.">
    <div class="roadmap">
      <div class="roadmap-card">
        <p class="t-label-small stage">Active</p>
        <h3 class="t-title">Android TV</h3>
        <p class="t-body-small">Available now on Google Play.</p>
      </div>
      <div class="roadmap-card">
        <p class="t-label-small stage">Next</p>
        <h3 class="t-title">Android Mobile</h3>
        <p class="t-body-small">Companion app for managing sources, profiles and devices on the go.</p>
      </div>
      <div class="roadmap-card">
        <p class="t-label-small stage">Planned</p>
        <h3 class="t-title">Apple TV · Samsung · LG</h3>
        <p class="t-body-small">tvOS, Tizen and webOS clients are on the roadmap. Same account, same entitlement, same cloud sync.</p>
      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  .download { display: grid; grid-template-columns: 1fr; gap: var(--space-xl); }
  @media (min-width: 900px) { .download { grid-template-columns: 1.3fr 1fr; align-items: start; } }

  .download-card {
    padding: var(--space-xl);
    border-radius: var(--radius-l);
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.22), rgba(139, 92, 246, 0.12));
    border: 1px solid rgba(96, 165, 250, 0.3);
    display: flex; flex-direction: column; gap: var(--space-m);
  }
  .platform { margin: 0; color: var(--color-accent-cyan); }
  .download-title { margin: 0; color: var(--color-on-surface-high); }
  .store-note { margin: 0; color: var(--color-on-surface-muted); }
  .store-note code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 14px;
    padding: 2px 6px;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-on-surface);
  }

  .requirements {
    padding: var(--space-xl);
    border-radius: var(--radius-l);
    background: linear-gradient(180deg, rgba(29, 33, 40, 0.6), rgba(20, 23, 28, 0.6));
    border: 1px solid rgba(255, 255, 255, 0.06);
    display: flex; flex-direction: column; gap: var(--space-m);
  }
  .requirements h3 { margin: 0; color: var(--color-on-surface-high); }
  .requirements ul {
    margin: 0; padding-left: 20px;
    color: var(--color-on-surface);
    display: flex; flex-direction: column; gap: var(--space-s);
  }

  .roadmap { display: grid; grid-template-columns: 1fr; gap: var(--space-l); }
  @media (min-width: 800px) { .roadmap { grid-template-columns: repeat(3, 1fr); } }
  .roadmap-card {
    padding: var(--space-l);
    border-radius: var(--radius-l);
    background: rgba(29, 33, 40, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.06);
    display: flex; flex-direction: column; gap: var(--space-s);
  }
  .stage { margin: 0; color: var(--color-accent-cyan); }
  .roadmap-card h3 { margin: 0; color: var(--color-on-surface-high); }
  .roadmap-card p  { margin: 0; }
</style>
