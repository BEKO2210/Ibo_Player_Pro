---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Section from "../components/Section.astro";
import Button from "../components/Button.astro";
import { WAITLIST_MAILTO } from "../utils/link";
---
<BaseLayout
  title="Download — Premium TV Player (demnächst)"
  description="Premium TV Player kommt demnächst in den Google Play Store für Android TV und Google TV. Android 8.0 Oreo (API 26) oder neuer. Trag dich in die Warteliste ein."
>
  <PageHeader
    eyebrow="Download"
    title="Demnächst im Google Play Store."
    lede="Premium TV Player ist in der letzten Vorbereitungsphase für den Google Play Store. Sobald die App freigegeben ist, installierst du sie in unter einer Minute auf jedem Google-TV- oder Android-TV-Gerät. Trag dich ein und du bekommst eine Mail, sobald der Store-Eintrag live ist."
  />

  <Section>
    <div class="download">
      <div class="download-card">
        <p class="t-label-small platform">Android TV · Google TV</p>
        <h2 class="t-headline download-title">Noch nicht im Play Store.</h2>
        <p class="t-body">
          Premium TV Player wird gerade final für die Einreichung vorbereitet. Sobald der
          Eintrag freigegeben ist, suchst du auf deinem TV nach <strong>Premium TV Player</strong>,
          oder du öffnest Google Play im Browser und schickst die Installation direkt auf dein TV.
        </p>
        <Button href={WAITLIST_MAILTO} label="Zum Start benachrichtigen" variant="primary" external />
        <p class="t-body-small store-note">
          Zukünftiges Package: <code>com.premiumtvplayer.app</code>
        </p>
      </div>

      <aside class="requirements">
        <h3 class="t-title">Systemvoraussetzungen</h3>
        <ul>
          <li><strong>Android 8.0 Oreo</strong> (API 26) oder neuer</li>
          <li>Android-TV- oder Google-TV-Gerät mit Leanback-Launcher</li>
          <li>Aktive Internetverbindung für Anmeldung, EPG-Sync &amp; Abrechnung</li>
          <li>Mindestens 100 MB freier Speicher</li>
          <li>Google-Konto (für Play Billing)</li>
        </ul>

        <h3 class="t-title">Getestet auf</h3>
        <ul>
          <li>Google TV Streamer, Chromecast mit Google TV, NVIDIA Shield TV</li>
          <li>Sony BRAVIA Google TV, TCL Google TV, Hisense Google TV</li>
          <li>Android-TV-Emulator (API 30+)</li>
        </ul>
      </aside>
    </div>
  </Section>

  <Section eyebrow="Weitere Plattformen" title="Kommt nach dem Start.">
    <div class="roadmap">
      <div class="roadmap-card">
        <p class="t-label-small stage">Start</p>
        <h3 class="t-title">Android TV</h3>
        <p class="t-body-small">Zuerst im Google Play Store — gerade in der finalen Vorbereitung.</p>
      </div>
      <div class="roadmap-card">
        <p class="t-label-small stage">Als nächstes</p>
        <h3 class="t-title">Android Mobile</h3>
        <p class="t-body-small">Begleit-App zum Verwalten von Quellen, Profilen und Geräten unterwegs.</p>
      </div>
      <div class="roadmap-card">
        <p class="t-label-small stage">Geplant</p>
        <h3 class="t-title">Apple TV · Samsung · LG</h3>
        <p class="t-body-small">tvOS-, Tizen- und webOS-Clients sind auf der Roadmap. Gleiches Konto, gleiche Lizenz, gleicher Cloud-Sync.</p>
      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  .download { display: grid; grid-template-columns: 1fr; gap: var(--space-xl); }
  @media (min-width: 900px) { .download { grid-template-columns: 1.3fr 1fr; align-items: start; } }

  .download-card {
    padding: clamp(20px, 4vw, 32px);
    border-radius: var(--radius-l);
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.22), rgba(139, 92, 246, 0.12));
    border: 1px solid rgba(96, 165, 250, 0.3);
    display: flex; flex-direction: column; gap: var(--space-m);
  }
  .platform { margin: 0; color: var(--color-accent-cyan); }
  .download-title { margin: 0; color: var(--color-on-surface-high); }
  .store-note { margin: 0; color: var(--color-on-surface-muted); }
  .store-note code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 14px;
    padding: 2px 6px;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-on-surface);
    word-break: break-all;
  }

  .requirements {
    padding: clamp(20px, 4vw, 32px);
    border-radius: var(--radius-l);
    background: linear-gradient(180deg, rgba(29, 33, 40, 0.6), rgba(20, 23, 28, 0.6));
    border: 1px solid rgba(255, 255, 255, 0.06);
    display: flex; flex-direction: column; gap: var(--space-m);
  }
  .requirements h3 { margin: 0; color: var(--color-on-surface-high); }
  .requirements ul {
    margin: 0; padding-left: 20px;
    color: var(--color-on-surface);
    display: flex; flex-direction: column; gap: var(--space-s);
  }

  .roadmap { display: grid; grid-template-columns: 1fr; gap: var(--space-l); }
  @media (min-width: 800px) { .roadmap { grid-template-columns: repeat(3, 1fr); } }
  .roadmap-card {
    padding: clamp(16px, 3.5vw, 24px);
    border-radius: var(--radius-l);
    background: rgba(29, 33, 40, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.06);
    display: flex; flex-direction: column; gap: var(--space-s);
  }
  .stage { margin: 0; color: var(--color-accent-cyan); }
  .roadmap-card h3 { margin: 0; color: var(--color-on-surface-high); }
  .roadmap-card p  { margin: 0; }
</style>
